{
    "version": "0.2.0",
    "configurations": [
        {
            "name": "Python Debugger: FastAPI",
            "type": "debugpy",
            "request": "launch",
            "module": "uvicorn",
            "args": [
                "app.main:app",
                "--reload",
                "--host=0.0.0.0",
                "--port=8010"
            ],
            "jinja": true,
            "cwd": "${workspaceFolder}"
        },
        {
            "name": "Python Debugger: arq worker",
            "type": "debugpy",
            "request": "launch",
            "module": "arq",
            "args": [
                "app.worker.WorkerSettings"
            ],
            "cwd": "${workspaceFolder}"
        }
    ],
    "compounds": [
        {
            "name": "Launch API + Worker",
            "configurations": [
                "Python Debugger: FastAPI",
                "Python Debugger: arq worker"
            ],
            "stopAll": true
        }
    ]
}